#!/bin/sh
# DMS-O2 Pre-commit hook
# Install: git config core.hooksPath .githooks

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "${GREEN}▸ DMS-O2 pre-commit checks${NC}"

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# --- Python checks ---
PYTHON_FILES=$(echo "$STAGED_FILES" | grep -E '\.py$' || true)
if [ -n "$PYTHON_FILES" ]; then
    echo "  Checking Python files..."

    # Syntax check (no imports needed)
    for file in $PYTHON_FILES; do
        if [ -f "$file" ]; then
            python3 -c "import py_compile; py_compile.compile('$file', doraise=True)" 2>/dev/null || {
                echo "${RED}  ✗ Syntax error in $file${NC}"
                exit 1
            }
        fi
    done
    echo "  ${GREEN}✓ Python syntax OK${NC}"

    # Check for common issues: bare except, mutable default args, print statements
    for file in $PYTHON_FILES; do
        if [ -f "$file" ]; then
            # Detect print() statements (should use logging)
            if grep -n "^\s*print(" "$file" | grep -v "# noqa" | grep -v "test" | grep -v "__repr__" > /dev/null 2>&1; then
                echo "${YELLOW}  ⚠ print() found in $file — consider using logging${NC}"
            fi
            # Detect TODO/FIXME/HACK without ticket reference
            if grep -n "TODO\|FIXME\|HACK\|XXX" "$file" | grep -v "# TODO(#" | grep -v "# FIXME(#" | grep -v "# noqa" > /dev/null 2>&1; then
                echo "${YELLOW}  ⚠ TODO/FIXME found in $file — reference a ticket${NC}"
            fi
        fi
    done
fi

# --- JavaScript/TypeScript checks ---
JS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|jsx|ts|tsx)$' || true)
if [ -n "$JS_FILES" ]; then
    echo "  Checking JS/TS files..."

    # Check for console.log statements
    for file in $JS_FILES; do
        if [ -f "$file" ]; then
            if grep -n "console\.log(" "$file" | grep -v "// " | grep -v "eslint-disable" > /dev/null 2>&1; then
                echo "${YELLOW}  ⚠ console.log() found in $file — remove before commit${NC}"
            fi
        fi
    done
    echo "  ${GREEN}✓ JS/TS basic checks OK${NC}"
fi

# --- Docker checks ---
DOCKER_FILES=$(echo "$STAGED_FILES" | grep -E '(Dockerfile|docker-compose)' || true)
if [ -n "$DOCKER_FILES" ]; then
    echo "  Checking Docker files..."
    for file in $DOCKER_FILES; do
        if [ -f "$file" ]; then
            # Basic syntax: check for empty FROM
            if grep -E "^FROM\s*$" "$file" > /dev/null 2>&1; then
                echo "${RED}  ✗ Empty FROM in $file${NC}"
                exit 1
            fi
        fi
    done
    echo "  ${GREEN}✓ Docker syntax OK${NC}"
fi

# --- Secret leak detection ---
echo "  Checking for secrets..."
LEAK_PATTERNS='(password|secret_key|api_key|token)\s*=\s*["\x27][^"\x27]{8,}'
LEAKS=$(echo "$STAGED_FILES" | while read -r file; do
    if [ -f "$file" ] && echo "$file" | grep -qE '\.(py|js|jsx|ts|tsx|env|yaml|yml|json)$'; then
        # Skip .env.example and test files
        echo "$file" | grep -qE '\.example$|test' && continue
        grep -inE "$LEAK_PATTERNS" "$file" 2>/dev/null | grep -v "CHANGE_ME" | grep -v "auto:" | grep -v "#" | head -5
    fi
done)

if [ -n "$LEAKS" ]; then
    echo "${RED}  ✗ Potential secrets found:${NC}"
    echo "$LEAKS"
    echo "${YELLOW}  If these are placeholders, add a comment on the same line to suppress.${NC}"
    exit 1
fi
echo "  ${GREEN}✓ No secrets detected${NC}"

echo "${GREEN}▸ All pre-commit checks passed${NC}"
