# =============================================================================
# DMS-O2 Environment Configuration
# =============================================================================
# Run setup.ps1 (Windows) or setup.sh (Linux/macOS) to auto-generate secrets.
# Or manually replace values below marked with "auto:" before starting.
# =============================================================================

# --- Database ---
POSTGRES_DB=dms
POSTGRES_USER=dms_user
POSTGRES_PASSWORD=auto:run_setup_to_generate
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Django ---
DJANGO_SECRET_KEY=auto:run_setup_to_generate
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Meilisearch ---
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=auto:run_setup_to_generate
MEILI_SEARCH_KEY=

# --- Root Account ---
ROOT_USERNAME=root
ROOT_PASSWORD=auto:run_setup_to_generate

# --- Session ---
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_TIMEOUT_HOURS=12

# --- Redis ---
REDIS_PASSWORD=auto:run_setup_to_generate

# --- Internal API ---
INTERNAL_API_SECRET=auto:run_setup_to_generate

# --- Backup ---
SEARCH_CACHE_TTL_SECONDS=10
HISTORY_RETENTION_DAYS=365
